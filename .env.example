# BuzzerMinds environment variables
# Copy this file to .env and fill in the values before running docker compose up.

# --- Required ---

# OpenRouter API key for LLM-powered question generation and grading.
OPENROUTER_API_KEY=

# --- Optional (with defaults) ---

# ElevenLabs API key for narration voice synthesis. Leave empty to disable narration.
ELEVENLABS_API_KEY=

# Postgres credentials. Defaults are fine for local dev but MUST be changed for production.
POSTGRES_DB=buzzerminds
POSTGRES_USER=buzzerminds
POSTGRES_PASSWORD=buzzerminds

# SearXNG secret key. Generate a random string for production.
SEARXNG_SECRET=buzzerminds-searxng-secret

# Cloudflare Turnstile (bot protection). Leave empty to disable.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
